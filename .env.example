APP_NAME=SaquePix
APP_ENV=development
# Gere um valor aleatório: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=troque-por-um-valor-aleatorio-de-64-caracteres-hex

# Gere o hash: php -r "echo password_hash('sua-senha', PASSWORD_BCRYPT);"
# Atenção: troque cada "$" do hash por "$$" neste arquivo (docker-compose interpola $ no .env)
ADMIN_EMAIL=admin@casepix.com
ADMIN_PASSWORD_HASH=troque-pelo-hash-bcrypt-da-sua-senha

DB_DRIVER=mysql
DB_HOST=banco
DB_PORT=3306
DB_DATABASE=saque_pix
DB_USERNAME=app
DB_PASSWORD=secret

MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@casepix.com
MAIL_FROM_NAME=CasePix

LOG_CHANNEL=stack
LOG_LEVEL=debug
